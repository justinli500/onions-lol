# ---------------------------------------------------------------------------
# onions.lol — environment template. Copy to .env.local (web) / .env (oracle).
# NEVER commit real values. Secrets (no NEXT_PUBLIC_) are server-only.
# ---------------------------------------------------------------------------

# --- Chain: 8453 = Base mainnet, 84532 = Base Sepolia ---
# Flip NEXT_PUBLIC_CHAIN_ID to retarget the whole web app (one switch: lib/chain.ts).
NEXT_PUBLIC_CHAIN_ID=8453
# Web/client RPC. Standardized name (the old NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL was never read).
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org
# USDC per chain: mainnet 0x833589..2913 (canonical Circle), sepolia 0x036CbD..3dCF7e.
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# --- Deployed contract addresses (fill after `forge script Deploy`) ---
NEXT_PUBLIC_ORACLE_ADDRESS=
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_FUTURES_ADDRESS=

# --- Privy (embedded wallets) — from dashboard.privy.io ---
NEXT_PUBLIC_PRIVY_APP_ID=
# Server-only secret — REQUIRED in production: the signer verifies the Privy
# session and binds the deposit address to the authenticated user.
PRIVY_APP_SECRET=

# --- Blink merchant signer (server-only) ---
# MERCHANT_ID from sandbox registration; MERCHANT_PRIVATE_KEY = PKCS#8 P-256 PEM
# (single line with literal \n, or multiline). Generate:
#   openssl ecparam -name prime256v1 -genkey -noout | openssl pkcs8 -topk8 -nocrypt
MERCHANT_ID=
MERCHANT_PRIVATE_KEY=
NEXT_PUBLIC_BLINK_ENV=sandbox
# Signer hardening: comma-separated extra allowed origins (same-origin always ok),
# and an upper bound on a single deposit.
ALLOWED_ORIGINS=
MAX_DEPOSIT_USD=10000

# --- Deploy (Foundry, server-only) ---
DEPLOYER_PRIVATE_KEY=
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=
# House seed in USDC 6dp base units (50000000 = $50). Reclaimable via Vault.withdrawHouse(amount).
HOUSE_SEED_USDC=

# --- Oracle keeper (separate process; reads its OWN non-NEXT_PUBLIC vars) ---
CHAIN_ID=8453
RPC_URL=https://mainnet.base.org
ORACLE_ADDRESS=
FUTURES_ADDRESS=
KEEPER_PRIVATE_KEY=
KEEPER_ADDRESS=
# On-chain mark push cadence (ms), decoupled from the chart's 12s tick. 60000 = 60s (mainnet).
KEEPER_PUSH_MS=60000

# --- Gas faucet (drips ETH to embedded wallets; falls back to KEEPER_PRIVATE_KEY if unset) ---
FAUCET_PRIVATE_KEY=

# --- USDA MARS API (server-only) — key is the Basic-auth USERNAME, blank pw ---
USDA_MARS_API_KEY=
