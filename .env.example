# ---------------------------------------------------------------------------
# onions.lol — environment template. Copy to .env.local (web) / .env (oracle).
# NEVER commit real values. Secrets (no NEXT_PUBLIC_) are server-only.
# ---------------------------------------------------------------------------

# --- Chain (Phase-1 confirmed: Blink sandbox delivers USDC on Base Sepolia) ---
NEXT_PUBLIC_CHAIN_ID=84532
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# --- Deployed contract addresses (fill after `forge script Deploy`) ---
NEXT_PUBLIC_ORACLE_ADDRESS=
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_FUTURES_ADDRESS=

# --- Privy (embedded wallets) — from dashboard.privy.io ---
NEXT_PUBLIC_PRIVY_APP_ID=

# --- Blink merchant signer (server-only) ---
# MERCHANT_ID from sandbox registration; MERCHANT_PRIVATE_KEY = PKCS#8 P-256 PEM
# (single line with literal \n, or multiline). Generate:
#   openssl ecparam -name prime256v1 -genkey -noout | openssl pkcs8 -topk8 -nocrypt
MERCHANT_ID=
MERCHANT_PRIVATE_KEY=
NEXT_PUBLIC_BLINK_ENV=sandbox

# --- Deploy / keeper (server-only) ---
DEPLOYER_PRIVATE_KEY=
KEEPER_PRIVATE_KEY=
KEEPER_ADDRESS=
FAUCET_PRIVATE_KEY=
BASESCAN_API_KEY=
HOUSE_SEED_USDC=

# --- USDA MARS API (server-only) — key is the Basic-auth USERNAME, blank pw ---
USDA_MARS_API_KEY=
